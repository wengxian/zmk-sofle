        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_navi {
        compatible = "zmk,combos";
        bindings = <&tog 1>;
        key-positions = <27 28 29>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_delete {
        compatible = "zmk,combos";
        bindings = <&kp DEL>;
        key-positions = <28 29>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_number {
        compatible = "zmk,combos";
        bindings = <&tog 2>;
        key-positions = <28 29 30>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_enter {
        compatible = "zmk,combos";
        bindings = <&kp ENTER>;
        key-positions = <29 30>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_fkeys {
        compatible = "zmk,combos";
        bindings = <&tog 3>;
