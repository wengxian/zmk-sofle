#define COMBO_TIMEOUT_MS 15

/ {
    combo_bootloader_1 {
        compatible = "zmk,combos";
        bindings = <&bootloader>;
        key-positions = <1 2 3 4>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_bootloader_2 {
        compatible = "zmk,combos";
        bindings = <&bootloader>;
        key-positions = <8 9 10 11>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_m_addr {
        compatible = "zmk,combos";
        bindings = <&macro_addr>;
        key-positions = <14 15 16>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_insert {
        compatible = "zmk,combos";
        bindings = <&kp INS>;
        key-positions = <15 16>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_lsft_lctrl_n {
        compatible = "zmk,combos";
        bindings = <&kp LC(LS(N))>;
        key-positions = <15 16 17>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_capslock {
        compatible = "zmk,combos";
        bindings = <&kp CLCK>;
        key-positions = <16 17>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_m_gmail {
        compatible = "zmk,combos";
        bindings = <&macro_gmail>;
