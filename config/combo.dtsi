        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_minus {
        compatible = "zmk,combos";
        bindings = <&kp MINUS>;
        key-positions = <21 22>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_left_parenthesis {
        compatible = "zmk,combos";
        bindings = <&kp LEFT_PARENTHESIS>;
        key-positions = <22 23>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_right_parenthesis {
        compatible = "zmk,combos";
        bindings = <&kp RIGHT_PARENTHESIS>;
        key-positions = <23 24>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_equal {
        compatible = "zmk,combos";
        bindings = <&kp EQUAL>;
        key-positions = <33 34>;
        timeout-ms = <COMBO_TIMEOUT_MS>;
    };

    combo_underscore {
        compatible = "zmk,combos";
        bindings = <&kp UNDERSCORE>;
